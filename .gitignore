# ==============================================================================
# PDF Tools
# .gitignore
#
# Purpose:
#     Ignore generated files, development artifacts, local configuration,
#     virtual environments, caches, and operating-system-specific files.
#
# Author:
#     Cory Funk
#
# Project:
#     PDF Tools
# ==============================================================================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
.test-venv/

# ------------------------------------------------------------------------------
# Distribution / Packaging
# ------------------------------------------------------------------------------
.Python
build/
dist/
downloads/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
share/python-wheels/
var/
wheels/
pip-wheel-metadata/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# ------------------------------------------------------------------------------
# Type Checking
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ------------------------------------------------------------------------------
# Ruff
# ------------------------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# Editors
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------------------------
# Local Configuration
# ------------------------------------------------------------------------------
.env
.env.*
config/local.*
config/*.local.*
*.local.yml
*.local.yaml

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
*.pid
*.sock

# ------------------------------------------------------------------------------
# Operating System
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
tmp/
temp/
*.tmp

# ------------------------------------------------------------------------------
# PDF Test Artifacts
# ------------------------------------------------------------------------------
test-output/
sample-output/
generated/
artifacts/

# ------------------------------------------------------------------------------
# Secrets
# ------------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# ------------------------------------------------------------------------------
# Backup Files
# ------------------------------------------------------------------------------
*.bak
*.old
*.orig
